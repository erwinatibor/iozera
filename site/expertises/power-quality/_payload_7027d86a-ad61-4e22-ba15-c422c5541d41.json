full_slug":30,"sort_by_date":139,"position":680,"tag_list":681,"is_startpage":142,"parent_id":674,"meta_data":139,"group_id":682,"first_published_at":683,"release_id":139,"lang":146,"path":139,"alternates":684,"default_full_slug":139,"translated_slugs":139,"_stopResolving":629},"2025-10-25T09:49:51.346Z","2026-01-13T21:23:42.583Z","2026-01-13T21:23:42.596Z",105251599781878,{"seo":412,"_uid":422,"name":423,"copy2":424,"image":442,"label":448,"projects":449,"component":284,"copy1_copy":466,"hero_intro":467,"hero_title":468,"industries":469,"intro_copy":470,"copy1_title":327,"intro_title":328,"return_cards":471,"feature_cards":488,"returns_title":404,"copy1_subtitle":564,"next_expertise":565,"short_description":678},[413],{"_uid":414,"image":415,"title":420,"component":191,"description":421},"4bca68a8-cc22-4881-a62c-a446925387a9",{"id":416,"alt":417,"name":18,"focus":18,"title":18,"source":18,"filename":418,"copyright":18,"fieldtype":188,"meta_data":419,"is_external_url":142},121197072913470,"OG AI Workloads","https://a.storyblok.com/f/288034353253643/1200x630/75413c2a91/og-ai-workloads.jpg",{"alt":417,"title":18,"source":18,"copyright":18},"AI UPS™ for Data Centers | Perfect Power, Grid Stability | ON.energy","Medium-voltage AI UPS™ delivers clean power for compute + cooling, absorbs volatility, enables ride-through, and streamlines interconnection at GW scale.","2df83d98-9fe7-461c-8b65-8cf505d8ea9d","AI Factories ",{"type":196,"content":425},[426,434],{"type":199,"attrs":427,"content":428},{"level":201,"textAlign":139},[429],{"text":430,"type":205,"marks":431},"Trusted by Hyperscalers.",[432],{"type":208,"attrs":433},{"color":18},{"type":211,"attrs":435,"content":436},{"textAlign":139},[437],{"text":438,"type":205,"marks":439},"AI UPS™ is deployed by the world’s leading AI and cloud operators to endure uninterrupted compute and perfect power quality. By integrating directly with grid infrastructure, it keeps data flowing, cooling online, and uptime absolute, even under extreme volatility.",[440],{"type":208,"attrs":441},{"color":18},{"id":443,"alt":444,"name":18,"focus":445,"title":18,"source":18,"filename":446,"copyright":18,"fieldtype":188,"meta_data":447,"is_external_url":142},121205817833803,"AI Workloads Hero","2902x1579:2903x1580","https://a.storyblok.com/f/288034353253643/4320x2430/a4add9cd4b/ai-workloads-hero.jpg",{"alt":444,"title":18,"source":18,"copyright":18},"AI UPS™",[450,458],{"_uid":451,"copy":452,"logo":453,"component":243},"2cea4e96-12dd-4455-91eb-b16ac08344fb","“We reviewed every credible solution on the market. ON.energy’s AI UPS was the only technology that met the full interconnection and reliability requirements, and their team was by far the strongest we worked with. This is poised to become the new standard for connecting AI factories in America.” – {{Chris Dolan}} Chief Data Center Officer",{"id":454,"alt":455,"name":18,"focus":18,"title":18,"source":18,"filename":456,"copyright":18,"fieldtype":188,"meta_data":457,"is_external_url":142},121239678959032,"Crusoe","https://a.storyblok.com/f/288034353253643/330x36/bae55c5b43/crusoe.svg",{"alt":455,"title":18,"source":18,"copyright":18},{"_uid":459,"copy":460,"logo":461,"component":243},"55010a94-b339-4e7c-bd26-b141546a053a","\"Working with ON.energy has been a pleasure from day one. While we've faced challenges together - as expected on any major project - it's clear that their team is made from exceptional stock. The professionalism and attention to detail from everyone on the On Energy side has been incredibly helpful in making this process as seamless as possible. We look forward to working with ON.energy on many future projects to come.\" - {{Clint Summers}}, PE Senior Director, Power Engineering",{"id":462,"alt":463,"name":18,"focus":18,"title":18,"source":18,"filename":464,"copyright":18,"fieldtype":188,"meta_data":465,"is_external_url":142},133733653269184,"Rosendin Logo (Steffen)","https://a.storyblok.com/f/288034353253643/330x36/b89abb0b1e/rosendin-logo-steffen.png",{"alt":463,"title":18,"source":18,"copyright":18},"Tested, certified, and deployed across leading hyperscale data centers, AI UPS™ delivers verified reliability and scalability at multi-gigawatt capacity.","{{AI workloads have outgrown}} traditional power design.\u2028AI UPS™ delivers perfect power quality inside the data hall while stabilizing the grid outside, proven at gigawatt scale with hyperscalers and utilities.","The AI Power\nQuality Problem",[],"{{AI workloads exceed the limits}} of traditional data center power design. UPS and interconnection systems can’t manage their density or volatility, while concentrated demand destabilizes the grid itself, creating a two-sided power quality challenge.",[472,481],{"_uid":473,"copy":474,"image":475,"title":480,"component":339},"23ed83ad-f865-490c-be1d-9a1861fe2bd4","MWh live delivering stability today",{"id":476,"alt":477,"name":18,"focus":18,"title":18,"source":18,"filename":478,"copyright":18,"fieldtype":188,"meta_data":479,"is_external_url":142},119116412556280,"AI Workloads returns","https://a.storyblok.com/f/288034353253643/2742x1538/970713ab0c/ai-workloads-return-card-1.jpg",{"alt":477,"title":18,"source":18,"copyright":18},"370+",{"_uid":482,"copy":474,"image":483,"title":487,"component":339},"790ba224-486b-47b2-a5f0-5ce2fdc4451d",{"id":484,"alt":477,"name":18,"focus":18,"title":18,"source":18,"filename":485,"copyright":18,"fieldtype":188,"meta_data":486,"is_external_url":142},119116412789753,"https://a.storyblok.com/f/288034353253643/4096x3067/49f8500274/ai-workloads-return-card-2.jpg",{"alt":477,"title":18,"source":18,"copyright":18},"1 GW",[489,502,534,549],{"_uid":490,"copy":491,"icon":498,"title":500,"number":501,"component":362,"map_background":142},"dca688e5-792f-4446-9003-cfc2861d5c39",{"type":196,"content":492},[493],{"type":211,"attrs":494,"content":495},{"textAlign":139},[496],{"text":497,"type":205},"Actively deploying over 2.5 gigawatts of AI UPS™ systems across multiple hyperscale campuses for multiple hyperscalers.",{"id":139,"alt":139,"name":18,"focus":139,"title":139,"source":139,"filename":18,"copyright":139,"fieldtype":188,"meta_data":499},{},"2.5 GW in Deployment","2.5{{GW}}",{"_uid":503,"copy":504,"icon":528,"title":533,"number":18,"component":362,"map_background":142},"b13f5fdd-6b01-4498-bc4a-c75580c69d9f",{"type":196,"content":505},[506],{"type":211,"attrs":507,"content":508},{"textAlign":139},[509,511,518,520,526],{"text":510,"type":205},"Tested at the ",{"text":512,"type":205,"marks":513},"National Laboratory of the Rockies",[514],{"type":515,"attrs":516},"link",{"href":517,"uuid":139,"anchor":139,"target":101,"linktype":102},"https://www.nrel.gov/",{"text":519,"type":205}," and the ",{"text":521,"type":205,"marks":522},"National Center for Reliable Electric Power Transmission",[523],{"type":515,"attrs":524},{"href":525,"uuid":139,"anchor":139,"target":101,"linktype":102},"https://ncrept.uark.edu/",{"text":527,"type":205},", confirming full performance under real-world grid conditions.",{"id":529,"alt":530,"name":18,"focus":18,"title":18,"source":18,"filename":531,"copyright":18,"fieldtype":188,"meta_data":532,"is_external_url":142},111590859812947,"Tree","https://a.storyblok.com/f/288034353253643/219x240/e0e7debdd5/tree.svg",{"alt":530,"title":18,"source":18,"copyright":18},"Validated by NLR & NCREPT",{"_uid":535,"copy":536,"icon":543,"title":548,"number":18,"component":362,"map_background":142},"bb2edc8d-cac6-4f3b-81cc-5b44ea790fe0",{"type":196,"content":537},[538],{"type":211,"attrs":539,"content":540},{"textAlign":139},[541],{"text":542,"type":205},"UL-certified and validated by key ISOs and utilities for large-scale, grid-safe interconnection.",{"id":544,"alt":545,"name":18,"focus":18,"title":18,"source":18,"filename":546,"copyright":18,"fieldtype":188,"meta_data":547,"is_external_url":142},111029055856190,"Checkmark","https://a.storyblok.com/f/288034353253643/177x177/f1be256648/checkmark.svg",{"alt":545,"title":18,"sourc